# Supabase (앱 인증용, 브라우저 노출 가능). 로컬은 npx supabase start 후 status 값 사용
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 로컬 개발용 DB: 설정 시 에이전트를 JSON 파일에 저장 (미설정 시 인메모리, 네이티브 빌드 없음)
# AGENT_STORE_PATH=./data/agents.json

# i18n 타임존 (IANA, 미설정 시 Asia/Seoul). 허용값: Asia/Seoul, Asia/Tokyo, America/New_York, America/Los_Angeles, Europe/London, Europe/Paris, UTC
# I18N_TIMEZONE=Asia/Seoul

# ── 인증 (Supabase OR env 토큰 중 하나만 설정) ─────────────────────────────
# 방법 A: Supabase (위 NEXT_PUBLIC_SUPABASE_* 설정 시 자동 사용)

# 방법 B: env 토큰 인증 (Supabase 없이 사용할 때)
# 다중 사용자: AUTH_USERS=email:token:role,email2:token2:role2  (role: viewer|operator|admin)
# AUTH_USERS=admin@example.com:change-this-secret-token:admin

# 단일 사용자 단축 설정 (AUTH_USERS와 중복 설정 가능)
# AUTH_EMAIL=admin@example.com
# AUTH_TOKEN=change-this-secret-token
# AUTH_ROLE=admin

# 세션 서명 시크릿 (미설정 시 내부 기본값 사용, 프로덕션에서는 반드시 설정)
# AUTH_SECRET=randomly-generated-64-char-string

# ── 게이트웨이 토큰은 서버 전용으로만 사용 (브라우저에 노출 금지) ─────────
# OPENCLAW_GATEWAY_TOKEN=...
# OPENCLAW_GATEWAY_URL=...
