# ============================================================
# 서버(배포)용 env 예제 (docker-compose --profile server 또는 프로덕션)
# 복사: cp examples/env.server.example .env.local (또는 서버 시크릿에 설정)
# ============================================================

# ---- 앱 (Next.js) ----

# [옵션 A] Supabase 인증 (외부 Supabase 프로젝트)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# [옵션 B] env 토큰 인증 ← 프라이빗 서버에 권장 (Supabase 불필요)
# 형식: email:token:role (role: viewer|operator|admin), 쉼표로 다중 사용자 추가 가능
AUTH_USERS=admin@your-domain.com:replace-with-secure-token:admin
# 반드시 강력한 랜덤 시크릿으로 교체 (기본값 사용 시 서버 로그 경고 출력)
# 생성: openssl rand -hex 32
AUTH_SECRET=replace-with-64-char-random-string

# ---- OpenClaw Gateway (서버에서만 사용, 브라우저 노출 금지) ----
# 같은 Docker 네트워크: ws://openclaw-gateway:18789
# 외부 Gateway: wss://gateway.your-domain.com
OPENCLAW_GATEWAY_URL=ws://openclaw-gateway:18789
OPENCLAW_GATEWAY_TOKEN=replace-with-secure-token

# ---- 에이전트 저장 (서버에서는 볼륨 마운트 경로 권장) ----
AGENT_STORE_PATH=/app/data/agents.json

# ---- 로깅 ----
# 프로덕션 권장: info 이상 (JSON 형식 출력)
LOG_LEVEL=info

# ---- 관측성 (Sentry) - 강력 권장 ----
# Sentry 프로젝트 생성 후 DSN 입력 (없으면 Sentry 비활성화)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oxx.ingest.sentry.io/xxx
SENTRY_DSN=https://xxx@oxx.ingest.sentry.io/xxx  # 서버 전용 (NEXT_PUBLIC_ 없이도 동작)
# 빌드 시 소스맵 Sentry 업로드 (CI 빌드에서 사용)
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=openclaw-dashboard
# SENTRY_AUTH_TOKEN=sntrys_xxx  # Sentry CI 업로드 토큰

# ---- i18n ----
# I18N_TIMEZONE=Asia/Seoul

# ---- GitHub Actions Secrets 설정 가이드 ----
# 아래 변수들은 GitHub Repository > Settings > Secrets & variables > Actions 에서 설정:
#
# AUTH_SECRET          → 프로덕션 세션 서명키 (openssl rand -hex 32)
# E2E_AUTH_EMAIL       → E2E 테스트용 로그인 이메일
# E2E_AUTH_TOKEN       → E2E 테스트용 로그인 토큰
# CODECOV_TOKEN        → 커버리지 리포트 업로드 (codecov.io에서 발급)
# SENTRY_AUTH_TOKEN    → Sentry 소스맵 업로드 토큰 (선택)
