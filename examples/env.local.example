# ============================================================
# 로컬 개발용 env 예제 (docker-compose --profile local 또는 로컬 npm run dev)
# 복사: cp examples/env.local.example .env.local
# ============================================================

# ---- 앱 (Next.js) ----
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# ---- OpenClaw Gateway (로컬 Docker 또는 호스트에서 gateway 실행 시) ----
# Docker 내부에서 접근: ws://openclaw-gateway:18789
# 호스트에서만 실행 시: ws://127.0.0.1:18789 또는 ws://host.docker.internal:18789
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# Gateway auth 사용 시에만 (gateway config에서 auth.enabled: true 일 때)
# OPENCLAW_GATEWAY_TOKEN=your-local-dev-token

# ---- 에이전트 저장 (로컬에서는 파일로 두면 재시작해도 유지) ----
AGENT_STORE_PATH=./data/agents.json

# ---- i18n ----
# I18N_TIMEZONE=Asia/Seoul
