# ============================================================
# 로컬 개발용 env 예제 (docker-compose --profile local 또는 로컬 npm run dev)
# 복사: cp examples/env.local.example .env.local
# ============================================================

# ---- 앱 (Next.js) ----

# [옵션 A] Supabase 인증 (로컬 Supabase: npx supabase start 후 status 값 사용)
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# [옵션 B] env 토큰 인증 ← 로컬 개발에 권장 (Supabase 불필요)
# 형식: email:token:role (role: viewer|operator|admin), 쉼표로 다중 사용자
AUTH_USERS=admin@example.com:devtoken:admin
# 세션 서명키 (최소 32자 이상 랜덤 문자열 권장)
# 생성: openssl rand -hex 32
AUTH_SECRET=local-dev-secret-change-in-production

# ---- OpenClaw Gateway (로컬 Docker 또는 호스트에서 gateway 실행 시) ----
# Docker 내부에서 접근: ws://openclaw-gateway:18789
# 호스트에서만 실행 시: ws://127.0.0.1:18789 또는 ws://host.docker.internal:18789
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# Gateway auth 사용 시에만 (gateway config에서 auth.enabled: true 일 때)
# OPENCLAW_GATEWAY_TOKEN=your-local-dev-token

# ---- 에이전트 저장 (로컬에서는 파일로 두면 재시작해도 유지) ----
AGENT_STORE_PATH=./data/agents.json

# ---- 로깅 ----
# 레벨: fatal | error | warn | info | debug | trace
# 개발환경 기본값: debug (pretty-print), 프로덕션 기본값: info (JSON)
# LOG_LEVEL=debug

# ---- 관측성 (Sentry) - 선택사항 ----
# Sentry 프로젝트 생성 후 DSN 입력 (없으면 Sentry 비활성화)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oxx.ingest.sentry.io/xxx
# SENTRY_DSN=https://xxx@oxx.ingest.sentry.io/xxx  # 서버 전용 (NEXT_PUBLIC_ 없이)
# SENTRY_ORG=your-org-slug                          # 빌드 시 소스맵 업로드용
# SENTRY_PROJECT=openclaw-dashboard                 # 빌드 시 소스맵 업로드용

# ---- i18n ----
# I18N_TIMEZONE=Asia/Seoul

# ---- E2E 테스트 (Playwright) - 선택사항 ----
# E2E_AUTH_EMAIL=admin@example.com
# E2E_AUTH_TOKEN=devtoken
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# ---- 기타 개발 도구 ----
# 번들 크기 분석: ANALYZE=true npm run build
# ANALYZE=false
